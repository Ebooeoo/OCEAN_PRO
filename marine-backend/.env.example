# Supabase PostgreSQL 连接字符串（在 Supabase 控制台 Settings > Database > Connection String 复制）
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# JWT 密钥（随机字符串，部署时请改成你自己的）
JWT_SECRET=marine_gdou_secret_2024_change_me

# 环境
NODE_ENV=production

# 端口（Koyeb 会自动注入 PORT，此处为本地备用）
PORT=3001
