# 后端环境变量示例（复制此文件为 .env，填入真实值）
# Railway 部署时在平台「Variables」页面配置这些变量，无需上传 .env 文件

# ===== 数据库（Railway MySQL 插件会自动注入以下变量）=====
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=railway

# ===== JWT 密钥（自己生成一个随机字符串，至少32位）=====
JWT_SECRET=your_jwt_secret_here_change_this

# ===== 服务端口（Railway 会自动设置 PORT，无需手动配置）=====
PORT=3001
